---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="关于 - Kano no Uta" description="关于 Kano 和这个叫 Kano no Uta 的个人博客。" i18nPage="about">
	<header class="page-heading" data-reveal>
		<p class="eyebrow" data-i18n="aboutEyebrow">About</p>
		<h1 data-i18n="aboutTitle">关于 Kano</h1>
		<p data-i18n="aboutLead">这里是一个重新开始写博客的人，和一个还在慢慢成形的小站。</p>
	</header>

	<section class="about-intro" data-reveal>
		<div class="about-avatar">
			<img src="/images/kano-rounded-avatar.png" alt="Kano" loading="lazy" decoding="async" />
		</div>
		<div class="about-content">
			<p data-i18n="aboutP1">你好，我是 Kano。这里是我重新整理出来的个人博客，名字叫 Kano no Uta。</p>
			<p data-i18n="aboutP2">它会先做一件很朴素的事：把文字留下来。技术笔记、踩坑记录、日常随笔、友链、旧文章迁移，都可以慢慢来。</p>
		</div>
	</section>

	<section class="about-social" data-reveal>
		<h2 data-i18n="aboutContactTitle">联系方式</h2>
		<div class="social-grid">
			<a class="social-card" href="mailto:hello@example.com">
				<span class="social-card__icon">
					<svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
				</span>
				<span class="social-card__info">
					<strong>Email</strong>
					<small>hello@example.com</small>
				</span>
			</a>
			<a class="social-card" href="https://github.com" target="_blank" rel="noreferrer">
				<span class="social-card__icon">
					<svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
				</span>
				<span class="social-card__info">
					<strong>GitHub</strong>
					<small>@username</small>
				</span>
			</a>
			<a class="social-card" href="https://twitter.com" target="_blank" rel="noreferrer">
				<span class="social-card__icon">
					<svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
				</span>
				<span class="social-card__info">
					<strong>X (Twitter)</strong>
					<small>@username</small>
				</span>
			</a>
		</div>
	</section>

	<section class="paper-sheet about-tech" data-reveal>
		<h3 data-i18n="aboutTechTitle">关于这个站点</h3>
		<p data-i18n="aboutTechText">使用 Astro 构建，部署在静态托管服务上。设计风格受到 Yohaku 和 async-area 的启发，融合了留白的克制与像素风格的复古感。</p>
		<ul>
			<li><strong data-i18n="aboutFramework">框架：</strong>Astro</li>
			<li><strong data-i18n="aboutStyle">样式：</strong><span data-i18n="nativeCss">原生 CSS + CSS Variables</span></li>
			<li><strong data-i18n="aboutFonts">字体：</strong><span data-i18n="siteFonts">系统字体 + BoutiqueBitmap</span></li>
			<li><strong data-i18n="aboutDeploy">部署：</strong><span data-i18n="staticHosting">静态托管</span></li>
		</ul>
	</section>
</BaseLayout>
