---
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPostSlug, sortPosts } from '../../lib/posts';
import { SITE_DESCRIPTION } from '../../consts';

const posts = sortPosts(await getCollection('blog'));
---

<BaseLayout title="文章 - Kano no Uta" description={SITE_DESCRIPTION} i18nPage="blog">
	<header class="page-heading" data-reveal>
		<p class="eyebrow" data-i18n="blogEyebrow">Posts</p>
		<h1 data-i18n="blogTitle">文章</h1>
		<p data-i18n="blogLead">按时间收起的记录。技术、生活、折腾，以及一些当下还没想清楚但值得留下的念头。</p>
	</header>

	<section class="post-list" aria-label="文章列表" data-i18n-aria-label="blogListLabel">
		{
			posts.map((post) => (
				<a class="post-card" href={getPostSlug(post)} data-reveal>
					<h2 data-i18n={`post.${post.id}.title`}>{post.data.title}</h2>
					<p data-i18n={`post.${post.id}.description`}>{post.data.description}</p>
					<FormattedDate date={post.data.pubDate} />
				</a>
			))
		}
	</section>
</BaseLayout>
