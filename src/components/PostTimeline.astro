---
import type { CollectionEntry } from 'astro:content';
import FormattedDate from './FormattedDate.astro';
import { getPostSlug } from '../lib/posts';

interface Props {
	posts: CollectionEntry<'blog'>[];
	limit?: number;
}

const { posts, limit } = Astro.props;
const visiblePosts = typeof limit === 'number' ? posts.slice(0, limit) : posts;
---

<div class="post-timeline">
	{
		visiblePosts.map((post, index) => (
			<article class="timeline-item" data-reveal style={`--timeline-index: ${index};`}>
				<span class="timeline-index">{String(index + 1).padStart(2, '0')}</span>
				<a href={getPostSlug(post)}>
					<div class="timeline-meta">
						<span data-i18n="articleType">文章</span>
						<span>·</span>
						<FormattedDate date={post.data.pubDate} />
					</div>
					<h3 data-i18n={`post.${post.id}.title`}>{post.data.title}</h3>
					<p data-i18n={`post.${post.id}.description`}>{post.data.description}</p>
				</a>
			</article>
		))
	}
</div>
