---
import type { CollectionEntry } from 'astro:content';
import FormattedDate from './FormattedDate.astro';
import { getPostSlug } from '../lib/posts';

interface Props {
	posts: CollectionEntry<'blog'>[];
	limit?: number;
}

const { posts, limit } = Astro.props;
const visiblePosts = typeof limit === 'number' ? posts.slice(0, limit) : posts;
---

<div class="post-list">
	{
		visiblePosts.map((post, index) => (
			<a class="post-card" href={getPostSlug(post)} data-reveal>
				<span class="post-card__marker" aria-hidden="true">
					{String(index + 1).padStart(2, '0')}
				</span>
				<div class="post-card__body">
					<div class="post-card__meta">
						<span data-i18n="articleType">文章</span>
						<span aria-hidden="true">·</span>
						<FormattedDate date={post.data.pubDate} />
					</div>
					<h3 data-i18n={`post.${post.id}.title`}>{post.data.title}</h3>
					<p data-i18n={`post.${post.id}.description`}>{post.data.description}</p>
				</div>
			</a>
		))
	}
</div>
