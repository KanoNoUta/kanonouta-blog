---
const today = new Date();
---

<footer class="site-footer">
	<div class="site-footer__inner">
		<div class="footer-brand">
			<span class="footer-brand__name">鹿の歌</span>
			<span class="footer-brand__desc">Kano no Uta</span>
		</div>
		
		<div class="footer-links">
			<div class="footer-group">
				<span class="footer-group__title" data-i18n="footerNavTitle">导航</span>
				<a href="/" data-i18n="home">首页</a>
				<a href="/blog" data-i18n="posts">文章</a>
				<a href="/links" data-i18n="links">友链</a>
				<a href="/lab" data-i18n="lab">Lab</a>
				<a href="/about" data-i18n="about">关于</a>
			</div>
			<div class="footer-group">
				<span class="footer-group__title" data-i18n="footerSubscribeTitle">订阅</span>
				<a href="/rss.xml">RSS</a>
				<a href="/blog" data-i18n="footerArchive">文章归档</a>
			</div>
			<div class="footer-group">
				<span class="footer-group__title" data-i18n="footerContactTitle">联系</span>
				<a href="mailto:hello@example.com">Email</a>
				<a href="https://github.com" target="_blank" rel="noreferrer">GitHub</a>
			</div>
		</div>
	</div>
	
	<div class="site-footer__bottom">
		<span>&copy; {today.getFullYear()} <span data-i18n="footerWritten">Kano. Written at kanonouta.com.</span></span>
		<span data-i18n="footerPowered">Powered by Astro.</span>
	</div>
</footer>
