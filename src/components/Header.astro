---
import HeaderLink from './HeaderLink.astro';
---

<header class="site-header">
	<nav class="site-nav" aria-label="主导航" data-i18n-aria-label="navLabel">
		<a class="site-brand" href="/" aria-label="Kano no Uta" data-i18n-aria-label="brandLabel">
			<span class="site-brand__cjk" data-i18n="brandCjk">鹿の歌</span>
			<span class="site-brand__latin">Kano no Uta</span>
		</a>
		<button class="nav-toggle" type="button" aria-label="打开导航" aria-expanded="false" aria-controls="nav-links" data-i18n-aria-label="openNav">
			<span></span>
			<span></span>
		</button>
		<div class="nav-links" id="nav-links">
			<span class="nav-indicator" aria-hidden="true"></span>
			<HeaderLink href="/" data-i18n="home">首页</HeaderLink>
			<HeaderLink href="/blog" data-i18n="posts">文章</HeaderLink>
			<HeaderLink href="/links" data-i18n="links">友链</HeaderLink>
			<div class="nav-menu">
				<HeaderLink href="/lab" data-i18n="lab">Lab</HeaderLink>
				<div class="nav-submenu" aria-label="Lab 子菜单" data-i18n-aria-label="labMenu">
					<a href="/lab/map/" data-i18n="map">地图</a>
				</div>
			</div>
			<HeaderLink href="/about" data-i18n="about">关于</HeaderLink>
			<a href="/rss.xml">RSS</a>
		</div>
		<div class="nav-locale">
			<div class="language-switcher" role="group" aria-label="Language" data-i18n-aria-label="languageLabel">
				<button class="language-switcher__button" type="button" data-lang-button="zh" aria-pressed="true" title="中文" data-i18n-title="languageZh">
					中
				</button>
				<button class="language-switcher__button" type="button" data-lang-button="ja" aria-pressed="false" title="日本語" data-i18n-title="languageJa">
					日
				</button>
				<button class="language-switcher__button" type="button" data-lang-button="en" aria-pressed="false" title="English" data-i18n-title="languageEn">
					EN
				</button>
			</div>
		</div>
	</nav>
</header>
