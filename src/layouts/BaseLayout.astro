---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

interface Props {
	title?: string;
	description?: string;
	class?: string;
	i18nPage?: string;
}

const {
	title = SITE_TITLE,
	description = SITE_DESCRIPTION,
	class: className = '',
	i18nPage = 'home',
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<script is:inline>
			const characterBackgrounds = [
				{ id: 'emilia', url: '/images/backgrounds/re0-emilia-flat.png' },
				{ id: 'beatrice', url: '/images/backgrounds/re0-beatrice-flat.png' },
				{ id: 'ram', url: '/images/backgrounds/re0-ram-flat.png' },
				{ id: 'rem', url: '/images/backgrounds/re0-rem-flat.png' },
			];
			const selectedBackground =
				characterBackgrounds[Math.floor(Math.random() * characterBackgrounds.length)];

			document.documentElement.style.setProperty(
				'--page-character-background',
				`url("${selectedBackground.url}")`,
			);
			document.documentElement.dataset.characterBackground = selectedBackground.id;
		</script>
		<BaseHead title={title} description={description} />
	</head>
	<body data-i18n-page={i18nPage}>
		<div class="scroll-progress" aria-hidden="true"></div>
		<div class="paper-light" aria-hidden="true"></div>
		<div class="page-shell">
			<Header />
			<main class:list={['site-main', className]}>
				<slot />
			</main>
			<Footer />
		</div>
		<script>
			import '../scripts/i18n.ts';
			import '../scripts/motion.ts';
		</script>
	</body>
</html>
